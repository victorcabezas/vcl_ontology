        <rdfs:comment>Address</rdfs:comment>
        <rdfs:label>address</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/def/base#coordType -->


    <owl:DatatypeProperty rdf:about="http://example.org/def/base#coordType">
