    </owl:DatatypeProperty>
    


    <!-- http://example.org/def/base#isFaultSystem -->


    <owl:DatatypeProperty rdf:about="http://example.org/def/base#isFaultSystem">
        <rdfs:domain rdf:resource="http://example.org/def/base#Substation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Whether to access the fault information of a remote transmission system</rdfs:comment>
        <rdfs:label>isFaultSystem</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/def/base#name -->


    <owl:DatatypeProperty rdf:about="http://example.org/def/base#name">
        <rdfs:domain rdf:resource="http://example.org/def/base#PowerThing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Object name</rdfs:comment>
        <rdfs:label>name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/def/base#normallyInService -->


    <owl:DatatypeProperty rdf:about="http://example.org/def/base#normallyInService">
        <rdfs:domain rdf:resource="http://pte2.namespace.com/def/#Equipment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Whether the equipment is in  normal operation</rdfs:comment>
        <rdfs:label>normallyInService</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/def/base#phases -->


    <owl:DatatypeProperty rdf:about="http://example.org/def/base#phases">
        <rdfs:domain rdf:resource="http://pte2.namespace.com/def/#ConductingEquipment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>It describes the phase corresponding to conducting equipment</rdfs:comment>
        <rdfs:label>phases</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/def/base#substationProperty -->


    <owl:DatatypeProperty rdf:about="http://example.org/def/base#substationProperty">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Property of substation</rdfs:comment>
        <rdfs:label>substationProperty</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/def/base#x -->


    <owl:DatatypeProperty rdf:about="http://example.org/def/base#x">
        <rdfs:domain rdf:resource="http://example.org/def/base#Location"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>Longitude, or other coordinates.</rdfs:comment>
        <rdfs:label>x</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/def/base#y -->


    <owl:DatatypeProperty rdf:about="http://example.org/def/base#y">
        <rdfs:domain rdf:resource="http://example.org/def/base#Location"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>Latitude, or other coordinates.</rdfs:comment>
        <rdfs:label>y</rdfs:label>
    </owl:DatatypeProperty>
    


