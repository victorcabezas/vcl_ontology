    </owl:Class>
    


    <!-- http://www.opengis.net/ont/geosparql#SpatialObject -->


    <owl:Class rdf:about="http://www.opengis.net/ont/geosparql#SpatialObject">
        <rdfs:label>Spatial Object</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/2003/01/geo/Point -->


    <owl:Class rdf:about="http://www.w3.org/2003/01/geo/Point">
        <rdfs:subClassOf rdf:resource="http://www.opengis.net/ont/geosparql#Geometry"/>
        <rdfs:label>Point</rdfs:label>
    </owl:Class>
    


    <!-- https://saref.etsi.org/core/v4.1.1/Device -->


    <owl:Class rdf:about="https://saref.etsi.org/core/v4.1.1/Device">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://mydomain.namespace.com/def/#locatedAt"/>
                <owl:allValuesFrom rdf:resource="https://saref.etsi.org/core/v4.1.1/Property"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>Device</rdfs:label>
    </owl:Class>
    


    <!-- https://saref.etsi.org/core/v4.1.1/Property -->


    <owl:Class rdf:about="https://saref.etsi.org/core/v4.1.1/Property">
        <rdfs:label>Property</rdfs:label>
    </owl:Class>
    


    <!-- https://saref.etsi.org/core/v4.1.1/Sensor -->


    <owl:Class rdf:about="https://saref.etsi.org/core/v4.1.1/Sensor">
        <rdfs:subClassOf rdf:resource="https://saref.etsi.org/core/v4.1.1/Device"/>
        <rdfs:label>Sensor</rdfs:label>
    </owl:Class>
    


