    <!-- http://example.org/def/base#connectTo -->


    <owl:ObjectProperty rdf:about="http://example.org/def/base#connectTo">
        <rdfs:domain rdf:resource="http://pte2.namespace.com/def/#ConnectivityNode"/>
        <rdfs:range rdf:resource="http://example.org/def/base#Terminal"/>
        <rdfs:comment>Terminals are connected at a node with zero impedance. The measure-ment of a node applies to all of its terminals.</rdfs:comment>
        <rdfs:label>connectTo</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/def/base#contain -->


    <owl:ObjectProperty rdf:about="http://example.org/def/base#contain">
