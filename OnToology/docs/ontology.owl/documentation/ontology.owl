    <!-- http://example.org/def/base#1 -->


    <owl:NamedIndividual rdf:about="http://example.org/def/base#1">
        <rdf:type rdf:resource="http://example.org/def/base#Substation"/>
        <isFaultSystem rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isFaultSystem>
    </owl:NamedIndividual>
    


    <!-- http://example.org/def/base#2 -->


    <owl:NamedIndividual rdf:about="http://example.org/def/base#2">
