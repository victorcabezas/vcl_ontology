    <!-- http://example.org/def/base#EquipmentContainer -->


    <owl:Class rdf:about="http://example.org/def/base#EquipmentContainer">
        <rdfs:subClassOf rdf:resource="http://example.org/def/base#PowerItem"/>
        <rdfs:label>EquipmentContainer</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/def/base#Location -->


    <owl:Class rdf:about="http://example.org/def/base#Location">
        <rdfs:comment>Geographical location</rdfs:comment>
        <rdfs:label>Location</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/def/base#Organization -->


    <owl:Class rdf:about="http://example.org/def/base#Organization">
        <rdfs:label>Organization</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/def/base#PowerEvent -->


    <owl:Class rdf:about="http://example.org/def/base#PowerEvent">
        <rdfs:subClassOf rdf:resource="http://example.org/def/base#PowerThing"/>
        <rdfs:label>PowerEvent</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/def/base#PowerItem -->


    <owl:Class rdf:about="http://example.org/def/base#PowerItem">
        <rdfs:subClassOf rdf:resource="http://example.org/def/base#PowerThing"/>
        <rdfs:comment>PowerItem refers to the items objectively existing in the electric power industry.</rdfs:comment>
        <rdfs:label>PowerItem</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/def/base#PowerThing -->


    <owl:Class rdf:about="http://example.org/def/base#PowerThing">
        <rdfs:label>PowerThing</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/def/base#Substation -->


    <owl:Class rdf:about="http://example.org/def/base#Substation">
        <rdfs:subClassOf rdf:resource="http://example.org/def/base#EquipmentContainer"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/def/base#isFaultSystem"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>Substation</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/def/base#Terminal -->


    <owl:Class rdf:about="http://example.org/def/base#Terminal">
        <rdfs:subClassOf rdf:resource="http://example.org/def/base#PowerItem"/>
        <rdfs:label>Terminal</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/def/base#Time -->


    <owl:Class rdf:about="http://example.org/def/base#Time">
        <rdfs:label>Time</rdfs:label>
    </owl:Class>
    


    <!-- http://iec.ch/TC57/2013/CIM-schema-cim17#EnergyConsumer -->


    <owl:Class rdf:about="http://iec.ch/TC57/2013/CIM-schema-cim17#EnergyConsumer">
        <rdfs:label>Energy Consumer</rdfs:label>
    </owl:Class>
    


    <!-- http://pte2.namespace.com/def/#ConductingEquipment -->


    <owl:Class rdf:about="http://pte2.namespace.com/def/#ConductingEquipment">
