        <rdfs:label>Conducting Equipment</rdfs:label>
    </owl:Class>
    


    <!-- http://pte2.namespace.com/def/#ConnectivityNode -->


    <owl:Class rdf:about="http://pte2.namespace.com/def/#ConnectivityNode">
        <rdfs:subClassOf rdf:resource="http://example.org/def/base#PowerItem"/>
        <rdfs:label>ConnectivityNode</rdfs:label>
    </owl:Class>
    


    <!-- http://pte2.namespace.com/def/#Equipment -->


    <owl:Class rdf:about="http://pte2.namespace.com/def/#Equipment">
        <rdfs:subClassOf rdf:resource="http://example.org/def/base#PowerItem"/>
        <rdfs:label>Equipment</rdfs:label>
    </owl:Class>
    


    <!-- http://pte2.namespace.com/def/#EquipmentContainer -->


    <owl:Class rdf:about="http://pte2.namespace.com/def/#EquipmentContainer">
        <rdfs:label>DEPRECATED Equipment Container</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    </owl:Class>
    


    <!-- http://pte2.namespace.com/def/#Line -->


    <owl:Class rdf:about="http://pte2.namespace.com/def/#Line">
        <rdfs:subClassOf rdf:resource="http://example.org/def/base#EquipmentContainer"/>
        <rdfs:label>Line</rdfs:label>
    </owl:Class>
    


    <!-- http://pte2.namespace.com/def/#ProtectionEquipment -->


    <owl:Class rdf:about="http://pte2.namespace.com/def/#ProtectionEquipment">
        <rdfs:subClassOf rdf:resource="http://pte2.namespace.com/def/#Equipment"/>
        <rdfs:label>Protection Equipment</rdfs:label>
    </owl:Class>
    


    <!-- http://www.opengis.net/ont/geosparql#Feature -->


    <owl:Class rdf:about="http://www.opengis.net/ont/geosparql#Feature">
        <rdfs:subClassOf rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:label>Feature</rdfs:label>
    </owl:Class>
    


    <!-- http://www.opengis.net/ont/geosparql#Geometry -->


    <owl:Class rdf:about="http://www.opengis.net/ont/geosparql#Geometry">
